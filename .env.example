# Copy this file to .env and fill in the values for production

# Database - Railway will provide this automatically if you add a MySQL plugin
DATABASE_URL=mysql://user:password@host:3306/arabic_teacher_db

# JWT Secret - generate a strong random string for production
JWT_SECRET=change-this-to-a-strong-secret-key-in-production

# OAuth (leave as is if not using OAuth)
VITE_OAUTH_PORTAL_URL=

# App
NODE_ENV=production
PORT=3000
